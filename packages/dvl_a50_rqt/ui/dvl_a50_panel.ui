<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
  <class>dvl_a50_panel</class>
  <widget class="QWidget" name="dvl_a50_panel">
    <property name="minimumSize">
      <size>
        <width>380</width>
        <height>700</height>
      </size>
    </property>
    <property name="windowTitle">
      <string>DVL-A50 Control</string>
    </property>
    <layout class="QVBoxLayout" name="main_layout">
      <property name="spacing">
        <number>6</number>
      </property>
      <property name="leftMargin">
        <number>6</number>
      </property>
      <property name="topMargin">
        <number>6</number>
      </property>
      <property name="rightMargin">
        <number>6</number>
      </property>
      <property name="bottomMargin">
        <number>6</number>
      </property>

      <!-- Configuration group -->
      <item>
        <widget class="QGroupBox" name="config_group">
          <property name="title">
            <string>Configuration</string>
          </property>
          <layout class="QGridLayout" name="config_grid">
            <property name="verticalSpacing">
              <number>4</number>
            </property>

            <!-- Speed of Sound -->
            <item row="0" column="0">
              <widget class="QLabel" name="label_sos">
                <property name="text">
                  <string>Speed of Sound:</string>
                </property>
              </widget>
            </item>
            <item row="0" column="1">
              <widget class="QSpinBox" name="sos_spinbox">
                <property name="minimum">
                  <number>1400</number>
                </property>
                <property name="maximum">
                  <number>1600</number>
                </property>
                <property name="value">
                  <number>1500</number>
                </property>
              </widget>
            </item>
            <item row="0" column="2">
              <widget class="QLabel" name="label_sos_unit">
                <property name="text">
                  <string>m/s</string>
                </property>
              </widget>
            </item>

            <!-- Acoustic Enabled -->
            <item row="1" column="0">
              <widget class="QLabel" name="label_acoustic">
                <property name="text">
                  <string>Acoustic:</string>
                </property>
              </widget>
            </item>
            <item row="1" column="1" colspan="2">
              <widget class="QCheckBox" name="acoustic_cb">
                <property name="text">
                  <string>Enabled</string>
                </property>
                <property name="checked">
                  <bool>true</bool>
                </property>
              </widget>
            </item>

            <!-- Dark Mode -->
            <item row="2" column="0">
              <widget class="QLabel" name="label_dark">
                <property name="text">
                  <string>Dark Mode:</string>
                </property>
              </widget>
            </item>
            <item row="2" column="1" colspan="2">
              <widget class="QCheckBox" name="dark_mode_cb">
                <property name="text">
                  <string>Enabled</string>
                </property>
                <property name="checked">
                  <bool>false</bool>
                </property>
              </widget>
            </item>

            <!-- Periodic Cycling -->
            <item row="3" column="0">
              <widget class="QLabel" name="label_periodic">
                <property name="text">
                  <string>Periodic Cycling:</string>
                </property>
              </widget>
            </item>
            <item row="3" column="1" colspan="2">
              <widget class="QCheckBox" name="periodic_cycling_cb">
                <property name="text">
                  <string>Enabled</string>
                </property>
                <property name="checked">
                  <bool>true</bool>
                </property>
              </widget>
            </item>

            <!-- Rotation Offset -->
            <item row="4" column="0">
              <widget class="QLabel" name="label_rotation">
                <property name="text">
                  <string>Rotation Offset:</string>
                </property>
              </widget>
            </item>
            <item row="4" column="1">
              <widget class="QDoubleSpinBox" name="rotation_spinbox">
                <property name="minimum">
                  <double>-180.0</double>
                </property>
                <property name="maximum">
                  <double>180.0</double>
                </property>
                <property name="singleStep">
                  <double>1.0</double>
                </property>
                <property name="value">
                  <double>0.0</double>
                </property>
              </widget>
            </item>
            <item row="4" column="2">
              <widget class="QLabel" name="label_rotation_unit">
                <property name="text">
                  <string>deg</string>
                </property>
              </widget>
            </item>

            <!-- Range Mode -->
            <item row="5" column="0">
              <widget class="QLabel" name="label_range">
                <property name="text">
                  <string>Range Mode:</string>
                </property>
              </widget>
            </item>
            <item row="5" column="1" colspan="2">
              <widget class="QComboBox" name="range_combo">
                <item>
                  <property name="text">
                    <string>auto</string>
                  </property>
                </item>
                <item>
                  <property name="text">
                    <string>high_resolution</string>
                  </property>
                </item>
                <item>
                  <property name="text">
                    <string>long_range</string>
                  </property>
                </item>
              </widget>
            </item>

            <!-- Config buttons -->
            <item row="6" column="0" colspan="3">
              <layout class="QHBoxLayout" name="config_btn_layout">
                <item>
                  <widget class="QPushButton" name="get_config_btn">
                    <property name="text">
                      <string>Get Config</string>
                    </property>
                  </widget>
                </item>
                <item>
                  <widget class="QPushButton" name="apply_config_btn">
                    <property name="text">
                      <string>Apply Config</string>
                    </property>
                  </widget>
                </item>
              </layout>
            </item>

          </layout>
        </widget>
      </item>

      <!-- Commands group -->
      <item>
        <widget class="QGroupBox" name="commands_group">
          <property name="title">
            <string>Commands</string>
