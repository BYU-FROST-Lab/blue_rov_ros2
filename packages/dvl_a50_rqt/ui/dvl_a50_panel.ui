              <widget class="QPushButton" name="reset_dr_btn">
                <property name="text">
                  <string>Reset Dead Reckoning</string>
                </property>
              </widget>
            </item>
          </layout>
        </widget>
      </item>

      <!-- Time / NTP group -->
      <item>
        <widget class="QGroupBox" name="ntp_group">
          <property name="title">
            <string>Time / NTP</string>
          </property>
          <layout class="QGridLayout" name="ntp_grid">
            <property name="verticalSpacing">
              <number>4</number>
            </property>

            <!-- NTP address input + Set button -->
            <item row="0" column="0">
              <widget class="QLabel" name="label_ntp_addr">
                <property name="text">
                  <string>NTP Address:</string>
                </property>
              </widget>
            </item>
            <item row="0" column="1">
              <widget class="QLineEdit" name="ntp_address_input">
                <property name="text">
                  <string>auto</string>
                </property>
                <property name="placeholderText">
                  <string>auto or IP address</string>
                </property>
              </widget>
            </item>
            <item row="0" column="2">
              <widget class="QPushButton" name="set_ntp_btn">
                <property name="text">
                  <string>Set NTP</string>
                </property>
              </widget>
            </item>

            <!-- Get NTP / Get Time Status buttons -->
            <item row="1" column="0" colspan="3">
              <layout class="QHBoxLayout" name="ntp_query_layout">
                <item>
                  <widget class="QPushButton" name="get_ntp_btn">
                    <property name="text">
                      <string>Get NTP Config</string>
                    </property>
                  </widget>
                </item>
                <item>
                  <widget class="QPushButton" name="get_time_status_btn">
                    <property name="text">
                      <string>Get Time Status</string>
                    </property>
                  </widget>
                </item>
              </layout>
            </item>

            <!-- Force Sync row -->
            <item row="2" column="0">
              <widget class="QLabel" name="label_force_sync">
                <property name="text">
                  <string>Force Sync:</string>
                </property>
              </widget>
            </item>
            <item row="2" column="1">
              <layout class="QHBoxLayout" name="force_sync_layout">
                <item>
                  <widget class="QSpinBox" name="force_sync_timeout">
                    <property name="minimum">
                      <number>1</number>
                    </property>
                    <property name="maximum">
                      <number>120</number>
                    </property>
                    <property name="value">
                      <number>10</number>
                    </property>
                    <property name="suffix">
                      <string> s</string>
                    </property>
                  </widget>
                </item>
              </layout>
            </item>
            <item row="2" column="2">
              <widget class="QPushButton" name="force_sync_btn">
                <property name="text">
                  <string>Force Sync NTP</string>
                </property>
              </widget>
            </item>

            <!-- Status display -->
            <item row="3" column="0" colspan="3">
              <widget class="QFrame" name="ntp_separator">
                <property name="frameShape">
                  <enum>QFrame::HLine</enum>
                </property>
                <property name="frameShadow">
                  <enum>QFrame::Sunken</enum>
                </property>
              </widget>
            </item>
            <item row="4" column="0">
              <widget class="QLabel" name="label_ntp_config">
                <property name="text">
                  <string>NTP:</string>
                </property>
              </widget>
            </item>
            <item row="4" column="1" colspan="2">
              <widget class="QLabel" name="ntp_config_label">
                <property name="text">
                  <string>address=--</string>
                </property>
                <property name="font">
                  <font>
                    <family>Monospace</family>
                  </font>
                </property>
              </widget>
            </item>
            <item row="5" column="0">
              <widget class="QLabel" name="label_time_status">
                <property name="text">
                  <string>Status:</string>
                </property>
              </widget>
            </item>
            <item row="5" column="1" colspan="2">
              <widget class="QLabel" name="time_status_label">
                <property name="text">
                  <string>synced=--  to=--  last=-- s</string>
                </property>
                <property name="font">
                  <font>
                    <family>Monospace</family>
                  </font>
                </property>
              </widget>
            </item>
            <item row="6" column="0">
              <widget class="QLabel" name="label_system_time">
                <property name="text">
                  <string>Time:</string>
                </property>
              </widget>
            </item>
            <item row="6" column="1" colspan="2">
              <widget class="QLabel" name="system_time_label">
                <property name="text">
                  <string>--</string>
                </property>
                <property name="font">
                  <font>
                    <family>Monospace</family>
                  </font>
                </property>
              </widget>
            </item>

          </layout>
        </widget>
